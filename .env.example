# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit secrets.

# Path to the SQLite database file (default: stan.db in project root)
DB_PATH=stan.db

# How often to poll for new stock prices and news, in seconds (default: 300 = 5 min)
POLL_INTERVAL_SECONDS=300

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Bind address for the web server (default: 127.0.0.1)
HOST=127.0.0.1

# Port for the web server (default: 8000)
PORT=8000
